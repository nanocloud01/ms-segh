    <dependencyManagement>
        <dependencies>
            <!-- Módulos internos - Control centralizado de versiones -->
            <dependency>
                <groupId>bo.gob.sigep.seg.shared</groupId>
                <artifactId>seg-shared</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>bo.gob.sigep.seg.perfiles</groupId>
                <artifactId>seg-perfiles</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>bo.gob.sigep.seg.accesos</groupId>
                <artifactId>seg-accesos</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>bo.gob.sigep.seg.usuarios</groupId>
                <artifactId>seg-usuarios</artifactId>
                <version>${project.version}</version>
            </dependency>
            <!-- PostgreSQL -->
            <dependency>
                <groupId>org.postgresql</groupId>
                <artifactId>postgresql</artifactId>
                <version>${postgresql.version}</version>
                <scope>runtime</scope>
            </dependency>
            <!-- MapStruct para mapping de objetos -->
            <dependency>
                <groupId>org.mapstruct</groupId>
                <artifactId>mapstruct</artifactId>
                <version>${mapstruct.version}</version>
            </dependency>
            <dependency>
                <groupId>org.mapstruct</groupId>
                <artifactId>mapstruct-processor</artifactId>
                <version>${mapstruct.version}</version>
                <scope>provided</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>
