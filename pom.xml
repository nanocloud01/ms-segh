    <groupId>bo.gob.sigep.seg</groupId>
    <artifactId>ms-seg</artifactId>
    <version>1.0-SNAPSHOT</version>
    <packaging>pom</packaging>
    <modules>
        <module>seg-perfiles</module>
        <module>seg-shared</module>
        <module>seg-accesos</module>
        <module>seg-usuarios</module>
        <module>seg-bootstrap</module>
